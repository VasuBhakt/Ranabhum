# Copy this to .env — never commit .env

# Kafka / Redpanda broker address
export KAFKA_BROKERS=redpanda:9092

export REDPANDA_ADVERTISE_HOST=localhost

# Redis address (for run state)
export REDIS_ADDR=redis:6379

# Number of concurrent bots to spawn per submission
export BOT_COUNT=10

# Orders per second per bot (total load = BOT_COUNT * RATE_PER_BOT)
export RATE_PER_BOT=50

# How long each stress-test run lasts
export RUN_DURATION=60s
