# --- DATABASE CONFIGURATION ---
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@timescaledb:5432/postgres
REDIS_URL=redis://redis:6379
REDIS_ADDR=redis:6379

# --- KAFKA CONFIGURATION ---
KAFKA_BROKERS=redpanda:29092

# --- SANDBOX ENGINE CONFIGURATION ---
SANDBOX_HOST=http://host.docker.internal
SANDBOX_ENGINE_URL=http://sandbox-engine:8080

# --- TELEMETRY CONFIGURATION ---
TELEMETRY_API_URL=http://telemetry-api:8001

# --- BOT FLEET WORKLOAD CONFIGURATION ---
BOT_COUNT=50
RATE_PER_BOT=100
RUN_DURATION=60s
